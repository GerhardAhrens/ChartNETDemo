<UserControl
    x:Class="ChartNETDemo.LifeLineControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ChartNETDemo"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="{Binding Path=ChartBackground, UpdateSourceTrigger=PropertyChanged}"
    mc:Ignorable="d">
    <Grid>
        <Canvas x:Name="PART_Canvas" Background="{Binding Path=ChartBackground, UpdateSourceTrigger=PropertyChanged}" />
    </Grid>
</UserControl>
